# ============================================
# DB는 하나만 쓰세요 (로컬/배포 공통)
# ============================================
# DATABASE_URL을 여기저기 바꾸지 말고, 하나로 통일하는 게 좋습니다.
#
# [방법 1] 서버에서 node로 직접 실행할 때 (Docker 아님)
#   → host 는 반드시 127.0.0.1. "db" 는 Docker 전용이라 직접 실행 시 getaddrinfo EAI_AGAIN 에러 납니다.
#   예: DATABASE_URL=mysql://devlist:비번@127.0.0.1:3306/devlist
#
# [방법 2] 로컬 PC와 배포 서버가 같은 DB를 쓸 때
#   → Railway 등 외부 MySQL 하나 두고, 로컬/서버 모두 그 주소 하나만 사용
#   예: DATABASE_URL=mysql://user:비번@호스트.rlwy.net:12345/DB이름
#
# 이 파일을 복사해 .env 로 만들고 값만 채우세요.
# ============================================

DATABASE_URL=mysql://유저:비번@127.0.0.1:3306/DB이름

# 서버와 DB가 같은 머신이면 위처럼 127.0.0.1 사용 (공유 IP 말고)
# 이미 DATABASE_URL에 공인 IP가 들어 있어도, 같은 서버에서 돌 때만 로컬로 바꾸려면:
# DATABASE_USE_LOCALHOST=1
# PORT=3000
# SESSION_SECRET=아무랜덤문자
# Node에서 직접 HTTPS 사용 시 (Docker 미사용): 인증서 생성 후 아래 설정
# SSL_ENABLE=1
# SSL_CERT_PATH=nginx/ssl/cert.pem
# SSL_KEY_PATH=nginx/ssl/key.pem
